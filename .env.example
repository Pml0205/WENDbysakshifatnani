# Frontend API Configuration
# Set this to your backend API URL
VITE_API_BASE_URL=https://api.wendbysakshifatnani.in

# Admin Panel URL (for redirects from frontend)
VITE_ADMIN_PANEL_URL=https://api.wendbysakshifatnani.in

# Next.js Admin Panel - Backend API URL (for API calls)
NEXT_PUBLIC_API_URL=https://api.wendbysakshifatnani.in

# EmailJS client-side integration (optional).
# If these are set, contact form uses EmailJS directly.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
