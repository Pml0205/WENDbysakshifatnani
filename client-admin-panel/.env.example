AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=client@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# Backward-compatible fallback used if MONGO_URI is not set.
MONGODB_URI=
MONGODB_DB=wend
CORS_ORIGIN=http://localhost:5173
# Render disk is ephemeral; keep false in production unless you accept temporary files.
ALLOW_LOCAL_UPLOADS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# Optional display name for outgoing mail; the actual sender address comes from SMTP_USER.
SMTP_FROM_EMAIL=WEND Contact
CONTACT_RECEIVER_EMAIL=wendbysakshifatnani@gmail.com