AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=client@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# Backward-compatible fallback used if MONGO_URI is not set.
MONGODB_URI=
MONGODB_DB=wend
CORS_ORIGIN=http://localhost:5173
# Render disk is ephemeral; keep false in production unless you accept temporary files.
ALLOW_LOCAL_UPLOADS=false
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_SENDER_EMAIL=sender@yourdomain.com
# Optional display name for outgoing mail.
SENDGRID_SENDER_NAME=WEND Contact
CONTACT_RECEIVER_EMAIL=wendbysakshifatnani@gmail.com